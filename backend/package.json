{
  "name": "commiters-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --format=esm --packages=external",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../database/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../database/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pino-http": "^10.3.0",
    "twilio": "^6.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.1",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.25.12",
    "prisma": "^5.19.1",
    "supertest": "^7.2.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.4"
  }
}
