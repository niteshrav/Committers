PORT=4000
# Comma-separated list of allowed frontend origins.
# Example: http://localhost:5173,http://127.0.0.1:5173,https://app.commiters.com
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Supabase connection string used by Prisma.
# Supabase provides a "Connection string" for Postgres.
DATABASE_URL=

# Optional email notification (not required for MVP).
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

